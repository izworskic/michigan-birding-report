{
  "routes": [
    { "src": "/saginaw-bay", "dest": "/public/saginaw-bay.html" },
    { "src": "/migration", "dest": "/public/migration.html" },
    { "src": "/(.*\\.(css|js|png|jpg|svg|ico|webp))", "dest": "/public/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=900, stale-while-revalidate=1800" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
