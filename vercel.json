{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/saginaw-bay", "dest": "/public/saginaw-bay.html" },
    { "src": "/species/(.*)", "dest": "/public/species.html" },
    { "src": "/region/(.*)", "dest": "/public/region.html" },
    { "src": "/migration", "dest": "/public/migration.html" },
    { "src": "/(.*\\.(css|js|png|jpg|svg|ico|webp))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=900, stale-while-revalidate=1800" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
