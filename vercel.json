{
  "rewrites": [
    { "source": "/saginaw-bay", "destination": "/saginaw-bay.html" },
    { "source": "/migration", "destination": "/migration.html" },
    { "source": "/species/:code", "destination": "/species.html" },
    { "source": "/((?!api/)(?!_next/)(?!.*\\.).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=900, stale-while-revalidate=1800" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
